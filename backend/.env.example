# Toast automated nightly data exports (SFTP)
# Enable via Toast Customer Care + Reports > Settings > Data Exports / SSH Keys.
# Docs: https://doc.toasttab.com/doc/platformguide/downloading_data_export_files.html

TOAST_SFTP_HOST=s-9b0f88558b264dfda.server.transfer.us-east-1.amazonaws.com
TOAST_SFTP_PORT=22
TOAST_SFTP_USERNAME=
TOAST_SFTP_EXPORT_ID=
TOAST_SFTP_PRIVATE_KEY_PATH=~/.ssh/toast_sftp

# Local SFTP simulation (no Docker/SSH): folder layout {LOCAL_ROOT}/{EXPORT_ID}/{YYYYMMDD}/ItemSelectionDetails.csv
# TOAST_SFTP_LOCAL_ROOT=../data/dev/toast-sftp
# TOAST_SFTP_EXPORT_ID=local_dev

# PostgreSQL (recommended). Omit to use SQLite at data/ingest/ingestion_runs.db
DATABASE_URL=postgresql+psycopg://pantry:pantry@localhost:5432/pantry

# Default restaurant when a request does not specify location
PANTRY_DEFAULT_LOCATION_ID=default
PANTRY_DEFAULT_LOCATION_NAME=Default Location
PANTRY_DEFAULT_TIMEZONE=America/Chicago

# Optional: override repo root when running CLI from another cwd
# PANTRY_REPO_ROOT=/path/to/Pantry
